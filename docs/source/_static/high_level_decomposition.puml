@startuml high_level_decomposition
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Pulseengine (Kiln Edition) - High-Level Component Decomposition

Person(user, "User", "Developer using Kiln")
Person(embedded_dev, "Embedded Developer", "Safety-critical system developer")

System_Boundary(kiln_system, "Pulseengine WebAssembly Runtime") {
    Container_Boundary(cli_layer, "CLI & Tools Layer") {
        Component(kilnd, "kilnd", "Rust Binary", "WebAssembly runtime daemon")
        Component(kiln_cli, "kiln", "Rust Library", "Public API facade")
    }
    
    Container_Boundary(component_layer, "Component Model Layer") {
        Component(kiln_component, "kiln-component", "Rust Library", "Component Model implementation")
        Component(kiln_host, "kiln-host", "Rust Library", "Host bindings & callbacks")
    }
    
    Container_Boundary(runtime_layer, "Execution Engine Layer") {
        Component(kiln_runtime, "kiln-runtime", "Rust Library", "Core runtime engine")
        Component(kiln_instructions, "kiln-instructions", "Rust Library", "Instruction execution")
        Component(kiln_decoder, "kiln-decoder", "Rust Library", "WASM binary decoder")
    }
    
    Container_Boundary(foundation_layer, "Foundation Layer") {
        Component(kiln_foundation, "kiln-foundation", "Rust Library", "Core types & safe memory")
        Component(kiln_error, "kiln-error", "Rust Library", "Error handling")
        Component(kiln_format, "kiln-format", "Rust Library", "WASM format definitions")
        Component(kiln_sync, "kiln-sync", "Rust Library", "Synchronization primitives")
    }
    
    Container_Boundary(platform_layer, "Platform Abstraction Layer") {
        Component(kiln_platform, "kiln-platform", "Rust Library", "OS abstraction")
        Component(kiln_logging, "kiln-logging", "Rust Library", "Logging infrastructure")
        Component(kiln_intercept, "kiln-intercept", "Rust Library", "Execution interception")
    }
}

System_Ext(wasm_module, "WebAssembly Module", "User's WASM binary")
System_Ext(os_services, "Operating System", "Linux/macOS/QNX/Zephyr/Bare-metal")

' Relationships
user --> kilnd : "Executes WASM via"
embedded_dev --> kiln_cli : "Integrates via"
kilnd --> kiln_cli : "Uses"
kiln_cli --> kiln_component : "Orchestrates"
kiln_cli --> kiln_runtime : "Manages"

kiln_component --> kiln_host : "Binds host functions"
kiln_component --> kiln_runtime : "Executes components"
kiln_runtime --> kiln_instructions : "Executes"
kiln_runtime --> kiln_decoder : "Loads modules"

kiln_runtime --> kiln_foundation : "Uses safe memory"
kiln_instructions --> kiln_foundation : "Memory operations"
kiln_decoder --> kiln_format : "Parses format"

kiln_foundation --> kiln_error : "Error handling"
kiln_foundation --> kiln_sync : "Thread safety"

kiln_runtime --> kiln_platform : "Platform services"
kiln_runtime --> kiln_logging : "Diagnostics"
kiln_host --> kiln_intercept : "Intercepts calls"

kilnd --> wasm_module : "Loads & executes"
kiln_platform --> os_services : "Abstracts"

@enduml