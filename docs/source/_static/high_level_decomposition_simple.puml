@startuml high_level_decomposition
title Pulseengine (Kiln Edition) - High-Level Component Decomposition

skinparam component {
    BackgroundColor #E6F3FF
    BorderColor #5755a9
    FontColor #2e3440
    ArrowColor #5755a9
}

skinparam package {
    BackgroundColor #F8F9FA
    BorderColor #E5E9F0
}

actor User as user
actor "Embedded Developer" as embedded_dev

package "CLI & Tools Layer" {
    component [kilnd\nWebAssembly runtime daemon] as kilnd
    component [kiln\nPublic API facade] as kiln_cli
}

package "Component Model Layer" {
    component [kiln-component\nComponent Model implementation] as kiln_component
    component [kiln-host\nHost bindings & callbacks] as kiln_host
}

package "Execution Engine Layer" {
    component [kiln-runtime\nCore runtime engine] as kiln_runtime
    component [kiln-instructions\nInstruction execution] as kiln_instructions
    component [kiln-decoder\nWASM binary decoder] as kiln_decoder
}

package "Foundation Layer" {
    component [kiln-foundation\nCore types & safe memory] as kiln_foundation
    component [kiln-error\nError handling] as kiln_error
    component [kiln-format\nWASM format definitions] as kiln_format
    component [kiln-sync\nSynchronization primitives] as kiln_sync
}

package "Platform Abstraction Layer" {
    component [kiln-platform\nOS abstraction] as kiln_platform
    component [kiln-logging\nLogging infrastructure] as kiln_logging
    component [kiln-intercept\nExecution interception] as kiln_intercept
}

database "WebAssembly Module" as wasm_module
cloud "Operating System" as os_services

' Relationships
user --> kilnd : "Executes WASM via"
embedded_dev --> kiln_cli : "Integrates via"
kilnd --> kiln_cli : "Uses"
kiln_cli --> kiln_component : "Orchestrates"
kiln_cli --> kiln_runtime : "Manages"

kiln_component --> kiln_host : "Binds host functions"
kiln_component --> kiln_runtime : "Executes components"
kiln_runtime --> kiln_instructions : "Executes"
kiln_runtime --> kiln_decoder : "Loads modules"

kiln_runtime --> kiln_foundation : "Uses safe memory"
kiln_instructions --> kiln_foundation : "Memory operations"
kiln_decoder --> kiln_format : "Parses format"

kiln_foundation --> kiln_error : "Error handling"
kiln_foundation --> kiln_sync : "Thread safety"

kiln_runtime --> kiln_platform : "Platform services"
kiln_runtime --> kiln_logging : "Diagnostics"
kiln_host --> kiln_intercept : "Intercepts calls"

kilnd --> wasm_module : "Loads & executes"
kiln_platform --> os_services : "Abstracts"

@enduml